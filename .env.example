# ─────────────────────────────────────────────────────────────────────────────
# ClauseGuard — Environment Variables
# Copy this file to .env.local for local dev.
# Add each variable to your Vercel project under Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase dashboard → your project → Settings → API

# The public URL for your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# The public anon key (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# The secret service role key — NEVER expose this client-side, server/cron only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Site URL ──────────────────────────────────────────────────────────────────
# Set to http://localhost:3000 locally.
# On Vercel: set to your production domain e.g. https://clauseguard.vercel.app
# Also add this URL in Supabase → Auth → URL Configuration → Site URL
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get this from: https://console.anthropic.com → API Keys
# Used for AI contract analysis — keep secret, server-side only
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Resend ────────────────────────────────────────────────────────────────────
# Get this from: https://resend.com → API Keys
# Used for sending deadline alert emails — keep secret, server-side only
RESEND_API_KEY=re_...

# ── Cron secret ───────────────────────────────────────────────────────────────
# A random string you generate yourself — used to secure the /api/cron/alerts endpoint
# Generate one with: openssl rand -base64 32
# Vercel Cron automatically passes this as the Authorization Bearer token
# if you name the variable exactly CRON_SECRET
CRON_SECRET=your-random-secret-here
